# ============================================================
# toLink-Service 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# application-dev.yml 通过环境变量同时服务 dev 和 prod 环境
# ============================================================

# ---- Spring Profile ----
# 激活的配置文件：local / dev
SPRING_PROFILES_ACTIVE=dev

# ---- 数据库（MySQL）----
# MySQL 主机地址
DB_HOST=localhost
# MySQL 端口
DB_PORT=3306
# 数据库名称
DB_NAME=tolink_rag_db
# 数据库用户名
DB_USERNAME=root
# 数据库密码
DB_PASSWORD=your-db-password-here

# ---- 连接池（Druid）----
# 初始连接数（生产建议 5）
DRUID_INITIAL_SIZE=0
# 最小空闲连接（生产建议 5）
DRUID_MIN_IDLE=0
# 最大活跃连接（生产建议 30）
DRUID_MAX_ACTIVE=8

# ---- Redis ----
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码
REDIS_PASSWORD=your-redis-password-here
# Redis 数据库编号（默认 0）
REDIS_DB=0

# ---- Kafka ----
# Kafka 集群地址（逗号分隔多个 broker）
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Kafka 安全协议（默认 SASL_PLAINTEXT）
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
# Kafka SASL 机制（默认 PLAIN）
KAFKA_SASL_MECHANISM=PLAIN
# Kafka SASL 用户名
KAFKA_SASL_USERNAME=root
# Kafka SASL 密码
KAFKA_SASL_PASSWORD=your-kafka-password-here
# Kafka Listener 是否自动启动（默认 true）
KAFKA_LISTENER_AUTO_STARTUP=true

# ---- MQ 组件 ----
# MQ 供应商：kafka / rabbitmq / none
TOLINK_MQ_VENDOR=kafka

# ---- MinIO（对象存储）----
# MinIO 服务地址（host:port）
MINIO_ENDPOINT=localhost:9000
# MinIO 访问密钥
MINIO_ACCESS_KEY=your-minio-access-key-here
# MinIO 密钥
MINIO_SECRET_KEY=your-minio-secret-key-here
# MinIO 原文件私有桶名（用户上传原文件，Java 写入，Python 只读）
MINIO_RAW_BUCKET=tolink-rag-raw
# MinIO 解析产物私有桶名（Python 写入 Markdown/图片，Java 只读）
MINIO_PRIVATE_BUCKET=tolink-rag-docs
# MinIO 公开存储桶名（公开读；存放博客图片、Markdown 正文与反馈附件）
MINIO_PUBLIC_BUCKET=tolink-public

# ---- 阿里云 OSS（可选，OSS_SERVICE_TYPE=aliyun-oss 时需要）----
# 阿里云 OSS 端点
ALIYUN_OSS_ENDPOINT=
# 阿里云 AccessKeyId
ALIYUN_OSS_ACCESS_KEY_ID=
# 阿里云 AccessKeySecret
ALIYUN_OSS_ACCESS_KEY_SECRET=your-aliyun-secret-here
# 阿里云公开桶名
ALIYUN_OSS_PUBLIC_BUCKET=
# 阿里云私有桶名
ALIYUN_OSS_PRIVATE_BUCKET=

# ---- OSS 通用 ----
# OSS 服务类型：local / minio / aliyun-oss
OSS_SERVICE_TYPE=minio

# ---- 文档文件 ----
# 内部服务访问地址
DOCUMENT_FILE_INTERNAL_BASE_URL=http://localhost:8080
# 内部服务 Token
DOCUMENT_FILE_SERVICE_TOKEN=your-service-token-here

# ---- 召回网关 (recall-gateway) ----
# Python RAG 服务地址（拼接 /api/v1/internal/recall/stream）
RAG_PYTHON_BASE_URL=http://localhost:8000
# 内部 JWT HS256 密钥（Java 签发端与 Python 验签端必须一致；生产用密钥管理系统）
RECALL_INTERNAL_JWT_SECRET=your-recall-jwt-secret-here
# 内部 JWT 有效期（秒）
RECALL_JWT_EXP_SECONDS=30
# 召回整体超时（毫秒）
RECALL_STREAM_TIMEOUT_MS=60000
# SseEmitter 超时相对整体超时的缓冲（毫秒），保证上游超时先触发 RECALL_TIMEOUT
RECALL_EMITTER_TIMEOUT_BUFFER_MS=5000
# 连接 Python 超时（毫秒）
RECALL_CONNECT_TIMEOUT_MS=3000
# 读取 Python 响应超时（毫秒）
RECALL_READ_TIMEOUT_MS=60000
# 每用户每分钟召回上限
RECALL_RATE_LIMIT_PER_MINUTE=10
# 召回转发线程池：核心/最大线程数、队列容量
RECALL_EXECUTOR_CORE_SIZE=8
RECALL_EXECUTOR_MAX_SIZE=32
RECALL_EXECUTOR_QUEUE_CAPACITY=64

# ---- LLM ----
# API Key 加密密钥（64 位十六进制字符串）
LLM_SECRET=your-llm-secret-here

# ---- 线程池 ----
# 核心线程数（生产建议 10）
THREAD_POOL_CORE_SIZE=5
# 最大线程数（生产建议 20）
THREAD_POOL_MAX_SIZE=10
# 队列大小（生产建议 100）
THREAD_POOL_QUEUE_CAPACITY=50
# 线程空闲存活秒数
THREAD_POOL_KEEP_ALIVE_SECONDS=60
# 线程名前缀（document-upload 池）
THREAD_POOL_THREAD_NAME_PREFIX=document-file-upload-

# ---- 日志 ----
# 应用日志级别（debug / info / warn / error）
LOG_LEVEL=debug
# MyBatis SQL 日志实现类（生产建议 org.apache.ibatis.logging.nologging.NoLoggingImpl）
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.stdout.StdOutImpl
