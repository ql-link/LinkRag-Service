<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qingluo.link.mapper.SystemProviderMapper">

    <resultMap id="SystemProviderResultMap" type="com.qingluo.link.model.dto.entity.SystemProvider">
        <id property="id" column="id"/>
        <result property="providerType" column="provider_type"/>
        <result property="providerName" column="provider_name"/>
        <result property="apiBaseUrl" column="api_base_url"/>
        <result property="supportedModels" column="supported_models"/>
        <result property="configSchema" column="config_schema"/>
        <result property="isActive" column="is_active"/>
        <result property="priority" column="priority"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, provider_type, provider_name, api_base_url, supported_models, config_schema,
        is_active, priority, created_at, updated_at
    </sql>

    <select id="selectActiveProviders" resultMap="SystemProviderResultMap">
        select
        <include refid="BaseColumns"/>
        from llm_system_provider
        where is_active = true
        order by priority desc, id asc
    </select>

    <select id="selectByProviderType" resultMap="SystemProviderResultMap">
        select
        <include refid="BaseColumns"/>
        from llm_system_provider
        where provider_type = #{providerType}
        limit 1
    </select>

    <select id="countByProviderType" resultType="long">
        select count(1)
        from llm_system_provider
        where provider_type = #{providerType}
    </select>

</mapper>
