<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qingluo.link.mapper.SysUserMapper">

    <resultMap id="SysUserResultMap" type="com.qingluo.link.model.dto.entity.SysUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="nickname" column="nickname"/>
        <result property="email" column="email"/>
        <result property="phone" column="phone"/>
        <result property="avatarUrl" column="avatar_url"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="lastLoginAt" column="last_login_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, username, password_hash, nickname, email, phone, avatar_url, role, status, last_login_at, created_at, updated_at
    </sql>

    <select id="selectByAccount" resultMap="SysUserResultMap">
        select
        <include refid="BaseColumns"/>
        from sys_user
        where username = #{account}
           or email = #{account}
        limit 1
    </select>

    <select id="selectByUsername" resultMap="SysUserResultMap">
        select
        <include refid="BaseColumns"/>
        from sys_user
        where username = #{username}
        limit 1
    </select>

    <select id="selectByEmail" resultMap="SysUserResultMap">
        select
        <include refid="BaseColumns"/>
        from sys_user
        where email = #{email}
        limit 1
    </select>

    <select id="selectByEmailExcludingUserId" resultMap="SysUserResultMap">
        select
        <include refid="BaseColumns"/>
        from sys_user
        where email = #{email}
          and id != #{userId}
        limit 1
    </select>

</mapper>
